{
  "manifest_version": 3,
  "name": "Gupy AutoApply",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage", "offscreen", "scripting"],
  "host_permissions": ["*://*.gupy.io/*"],
  "background": { "service_worker": "dist/service-worker.js" },
  "content_scripts": [{
    "matches": ["*://*.gupy.io/*"],
    "js": ["dist/content.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "dist/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
