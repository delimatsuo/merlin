rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — only the user can read/write their own data
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Profiles subcollection
      match /profiles/{profileId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        // PII subcollection — tighter access, same rule but logically separated
        match /pii/{piiDoc} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }

      // Knowledge subcollection — read: owner, write: backend only
      match /knowledge/{doc} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // LinkedIn subcollection — read: owner, write: backend only (RA-2)
      match /linkedin/{doc} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Job preferences — user can read/write their own
      match /jobPreferences/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Matched jobs — read-only for user, write by batch job via Admin SDK
      match /matchedJobs/{date} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Applications subcollection
      match /applications/{applicationId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        // Resume versions
        match /resumes/{versionId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }

    // Voice sessions — user can only access their own sessions
    match /voiceSessions/{sessionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Company cache — read-only for authenticated users, write by backend service account
    match /companyCache/{companyId} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend service account via Admin SDK
    }

    // Jobs catalog — read-only for authenticated users, write by batch job via Admin SDK
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Batch run tracking — backend-only via Admin SDK
    match /jobs/batchRuns/{date} {
      allow read, write: if false;
    }

    // Platform stats — backend-only via Admin SDK
    match /platformStats/{date} {
      allow read, write: if false;
    }

    // Generation log — backend-only via Admin SDK
    match /generationLog/{id} {
      allow read, write: if false;
    }

    // Admin settings — backend-only via Admin SDK
    match /admin/{doc} {
      allow read, write: if false;
    }

    // Admin audit log — backend-only via Admin SDK
    match /adminAuditLog/{id} {
      allow read, write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
