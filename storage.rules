rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // User uploads — only the owner can read/write
    match /uploads/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024  // 10MB max
                   && (request.resource.contentType.matches('application/pdf')
                       || request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document')
                       || request.resource.contentType.matches('application/octet-stream'));
    }

    // Exported documents — only the owner can read
    match /exports/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Only backend via Admin SDK
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
